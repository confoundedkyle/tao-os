# ───────────────────────────────────────────────────────────────────────────
# Calyflow environment configuration
#
# Copy this file to `.env.local` and fill in the values:
#   cp .env.example .env.local
#
# `.env.local` is gitignored — never commit real secrets.
# ───────────────────────────────────────────────────────────────────────────

# ─── Supabase (required) ───────────────────────────────────────────────────
# Project URL and keys from your Supabase project:
#   Dashboard → Project Settings → API
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
# Public anon key — safe to expose to the browser.
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# ─── App security (required) ───────────────────────────────────────────────
# Secret used to encrypt provider API keys at rest. Generate a strong value:
#   openssl rand -base64 32
APP_ENCRYPTION_KEY=change-me-to-a-long-random-string

# ─── Auth / workspace mode ─────────────────────────────────────────────────
# Self-host mode: no Clerk orgs, every user lands in one shared workspace.
# Defaults to single-workspace whenever CLERK_SECRET_KEY is unset.
SINGLE_WORKSPACE=true
# Comma-separated list of emails granted admin rights.
ADMIN_EMAILS=you@example.com

# Clerk (multi-workspace mode) — leave blank to stay in single-workspace mode.
# Dashboard → API Keys
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
# Webhooks → add endpoint /api/webhooks/clerk, subscribe to organization.updated,
# then paste its Signing Secret here so Clerk org renames sync back to the DB.
CLERK_WEBHOOK_SIGNING_SECRET=

# ─── Calyflow platform provider (optional) ─────────────────────────────────
# When set, offers a hosted "Calyflow default" AI provider so users can run
# workflows without bringing their own key. Set ENABLED=false to disable.
PLATFORM_PROVIDER_ENABLED=false
CALYFLOW_PLATFORM_API_KEY=
CALYFLOW_PLATFORM_MODEL=claude-sonnet-4-6
# Free credit (USD) granted to new workspaces on the platform provider.
ONE_TIME_PLATFORM_CREDIT_DEFAULT_USD=11.00

# ─── Cron / scheduled jobs (optional) ──────────────────────────────────────
# Shared secret required in the Authorization header of cron endpoints.
CRON_SECRET=

# ─── Development ───────────────────────────────────────────────────────────
# Stream a canned response instead of calling a real AI provider.
MOCK_AI=false
