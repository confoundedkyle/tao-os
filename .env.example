# ───────────────────────────────────────────────────────────────────────────
# Calyflow environment configuration
#
# Copy this file to `.env.local` and fill in the values:
#   cp .env.example .env.local
#
# `.env.local` is gitignored — never commit real secrets.
# ───────────────────────────────────────────────────────────────────────────

# ─── Supabase (required) ───────────────────────────────────────────────────
# Project URL and keys from your Supabase project:
#   Dashboard → Project Settings → API
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
# Public anon key — safe to expose to the browser.
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# ─── App security (required) ───────────────────────────────────────────────
# Secret used to encrypt provider API keys at rest. Generate a strong value:
#   openssl rand -base64 32
APP_ENCRYPTION_KEY=change-me-to-a-long-random-string

# ─── Auth / workspace mode ─────────────────────────────────────────────────
# Self-host mode: no Clerk orgs, every user lands in one shared workspace.
# Defaults to single-workspace whenever CLERK_SECRET_KEY is unset.
SINGLE_WORKSPACE=true
# Comma-separated list of emails granted admin rights.
ADMIN_EMAILS=you@example.com
# STRONGLY RECOMMENDED for any internet-reachable single-workspace deployment:
# a shared passphrase required at sign-in. Without it, anyone who can reach the
# app can sign in as any email — and become admin by typing an ADMIN_EMAILS
# address. Leave unset only for local dev or instances behind network auth.
SINGLE_WORKSPACE_PASSWORD=

# Clerk (multi-workspace mode) — leave blank to stay in single-workspace mode.
# Dashboard → API Keys
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
# Webhooks → add endpoint /api/webhooks/clerk, subscribe to organization.updated,
# then paste its Signing Secret here so Clerk org renames sync back to the DB.
CLERK_WEBHOOK_SIGNING_SECRET=

# ─── Calyflow platform provider (optional) ─────────────────────────────────
# When set, offers a hosted "Calyflow default" AI provider so users can run
# workflows without bringing their own key. Set ENABLED=false to disable.
PLATFORM_PROVIDER_ENABLED=false
CALYFLOW_PLATFORM_API_KEY=
# The real provider the key + model belong to. Must match the key:
# anthropic (sk-ant-…) | openai (sk-…) | google | mistral | xai | deepseek | groq | cohere
CALYFLOW_PLATFORM_PROVIDER=anthropic
# A model id for that provider (e.g. claude-sonnet-4-6 for anthropic, gpt-5.1 for openai).
CALYFLOW_PLATFORM_MODEL=claude-sonnet-4-6
# Free credit (USD) granted to new workspaces on the platform provider.
ONE_TIME_PLATFORM_CREDIT_DEFAULT_USD=11.00

# ─── Cron / scheduled jobs (optional) ──────────────────────────────────────
# Shared secret required in the Authorization header of cron endpoints.
CRON_SECRET=

# ─── Client domain import (optional) ───────────────────────────────────────
# Firecrawl powers the "Import from domain" researcher on the client knowledge
# base (scrapes the site + key subpages). The import option only appears when
# this is set. Get a key at https://www.firecrawl.dev → Dashboard → API Keys.
FIRECRAWL_API_KEY=
# Hunter.io (optional) — when set, the importer enriches the company profile
# with key contacts. https://hunter.io → API.
HUNTER_API_KEY=

# ─── Data-source connectors (optional) ─────────────────────────────────────
# Public base URL of this deployment, used to build OAuth redirect URIs
# (no trailing slash). e.g. https://app.calyflow.com or http://localhost:3000
APP_BASE_URL=http://localhost:3000
# Airtable OAuth app (https://airtable.com/create/oauth). Register the redirect
# URL as ${APP_BASE_URL}/api/connectors/airtable/callback and request scopes
# data.records:read schema.bases:read
AIRTABLE_CLIENT_ID=
AIRTABLE_CLIENT_SECRET=

# ─── Development ───────────────────────────────────────────────────────────
# Stream a canned response instead of calling a real AI provider.
MOCK_AI=false
